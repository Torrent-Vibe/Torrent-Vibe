{
  "name": "torrent-vibe",
  "type": "module",
  "version": "1.0.1",
  "packageManager": "pnpm@11.1.2",
  "author": "Torrent Vibe Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/innei-template/vite-react-tailwind-template"
  },
  "main": "./dist/main/index.js",
  "scripts": {
    "build": "vite build",
    "build:electron": "pnpm build:native && pnpm electron:build && electron-builder --mac dmg zip --arm64 --publish never",
    "build:native": "bash native/build-all.sh",
    "build:production": "vite build --mode production",
    "build:render-release": "cross-env NODE_ENV=production ELECTRON_RENDER_BUILD=1 vite build --mode production",
    "build:turbo": "turbo run build --filter=@torrent-vibe/*",
    "dev": "vite",
    "predev:electron": "pnpm build:native",
    "dev:electron": "node scripts/dev-electron.mjs",
    "electron:build": "vite build --config vite.config.electron.ts && tsdown",
    "electron:make": "electron-builder --publish never",
    "electron:make:darwin": "pnpm build:native && electron-builder --mac dmg zip --arm64 --publish never",
    "electron:make:win32": "electron-builder --win nsis --x64 --publish never",
    "electron:make:linux": "electron-builder --linux AppImage --x64 --publish never",
    "format": "prettier --write \"src/**/*.ts\" ",
    "gen:icons": "bash scripts/generate-icons.sh",
    "license:check": "node scripts/check-licenses.js",
    "license:update": "node scripts/update-licenses.js",
    "lint": "eslint --fix",
    "prepare": "simple-git-hooks",
    "release:dry-run": "bash scripts/release-dry-run.sh",
    "serve": "vite preview",
    "start:electron": "pnpm electron:build && electron .",
    "typecheck": "pnpm -F @torrent-vibe/renderer typecheck",
    "typecheck:main": "pnpm -F @torrent-vibe/main typecheck",
    "typecheck:renderer": "pnpm -F @torrent-vibe/renderer typecheck",
    "typecheck:turbo": "turbo run typecheck --filter=@torrent-vibe/*"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "bufferutil": "4.1.0",
    "electron-liquid-glass": "^1.1.1",
    "node-gyp-build": "^4.8.4",
    "sqlite3": "^6.0.1",
    "utf-8-validate": "6.0.6"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "1.9.2",
    "@electron/asar": "4.2.0",
    "@electron/fuses": "2.1.2",
    "@iconify-json/lucide": "1.2.112",
    "@iconify-json/mingcute": "1.2.7",
    "@innei/prettier": "^1.0.0",
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "10.5.0",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "code-inspector-plugin": "1.6.0",
    "cross-env": "10.1.0",
    "electron": "42.4.0",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "4.0.0",
    "eslint": "10.5.0",
    "eslint-config-hyoban": "7.0.3",
    "lint-staged": "17.0.7",
    "postcss": "8.5.15",
    "postcss-import": "16.1.1",
    "postcss-js": "5.1.0",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "tailwind-scrollbar": "4.0.2",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.3.1",
    "tailwindcss-animate": "1.0.7",
    "tailwindcss-safe-area": "1.3.0",
    "tsdown": "^0.22.7",
    "turbo": "^2.9.18",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-bundle-analyzer": "1.3.8",
    "vite-plugin-checker": "0.14.1",
    "vite-plugin-node-polyfills": "0.28.0",
    "vite-plugin-route-builder": "0.4.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --ignore-path ./.gitignore --write "
    ],
    "*.{js,ts,cjs,mjs,jsx,tsx,json}": [
      "eslint --fix"
    ]
  },
  "productName": "Torrent Vibe"
}
